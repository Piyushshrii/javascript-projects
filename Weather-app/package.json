{
  "scripts": {
    "pretest": "rm -rf test-artifacts && mkdir test-artifacts",
    "test": "jest --ci --reporters=default --reporters=jest-junit --json --outputFile=test-artifacts/jest-results.json --coverage --coverageDirectory=test-artifacts/coverage"
  },
  "jest": {
    "coverageReporters": [
      "json",
      "text",
      "lcov"
    ]
  },
  "jest-junit": {
    "outputDirectory": "test-artifacts",
    "outputName": "jest-results.xml"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-junit": "^16.0.0"
  }
}
